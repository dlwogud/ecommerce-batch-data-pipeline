# Copy this file to `.env` and adjust values for your environment.
#   cp .env.example .env
#
# docker-compose reads `.env` automatically. Every variable below has a
# safe local default in docker-compose.yml (via ${VAR:-default}), so the
# stack still runs without a .env file — this only lets you override
# credentials without editing tracked files. Never commit a real .env.

# --- Source (operational) database ---
SOURCE_DB_USER=source_user
SOURCE_DB_PASSWORD=source_password
SOURCE_DB_NAME=ecommerce_source

# --- Warehouse (analytics) database ---
WAREHOUSE_DB_USER=warehouse_user
WAREHOUSE_DB_PASSWORD=warehouse_password
WAREHOUSE_DB_NAME=ecommerce_warehouse

# --- Airflow metadata database ---
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow

# --- Airflow web UI ---
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
AIRFLOW_WEBSERVER_SECRET_KEY=ecommerce_batch_pipeline
